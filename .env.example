# ── Bot & AI ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # Get from @BotFather on Telegram
ALLOWED_USER_IDS=          # Comma-separated numeric Telegram User IDs (get from @userinfobot)
GEMINI_API_KEY=            # Google Gemini API Key
GEMINI_MODEL=gemini-2.0-pro-exp-02-05

# ── Voice & Audio ─────────────────────────────────────────────────────
OPENAI_API_KEY=            # Required for Whisper voice-to-text transcription
ELEVENLABS_API_KEY=        # Required for Text-to-Speech voice replies

# ── Memory (Supabase & Pinecone) ──────────────────────────────────────
SUPABASE_URL=              # Your Supabase Project URL
SUPABASE_ANON_KEY=         # Your Supabase Project Anon/Public Key
PINECONE_API_KEY=          # Your Pinecone API Key
PINECONE_INDEX_NAME=       # Your Pinecone Index Name

# ── Polymarket ────────────────────────────────────────────────────────
# Note: Currently uses public read-only APIs. No keys required for search/details/monitoring.
MONITOR_THRESHOLD_USD=2000       # USD threshold for automated background alerts
MONITOR_ENABLED=true             # Enable/disable the background monitor
POLYGONSCAN_API_KEY=             # Optional: Used for advanced wallet age/funding checks
POLYMARKET_PRIVATE_KEY=          # Required for trading/orders via @iqai/mcp-polymarket
